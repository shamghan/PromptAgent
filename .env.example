# Prompt Agent Portal environment variables
# Copy this file to .env and fill in your actual key.
VITE_GROQ_API_KEY=your_groq_api_key_here

# Gemini (used for both Gemini models and Gemma)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Gemma via Gemini (separate key if different)
VITE_GEMINI2_API_KEY=your_gemini2_api_key_here

# Mistral AI
VITE_MISTRAL_API_KEY=your_mistral_api_key_here
